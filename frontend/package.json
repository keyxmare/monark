{
  "name": "monark-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "vue": "^3.5",
    "vue-router": "^4.5",
    "pinia": "^3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0",
    "@vue/test-utils": "^2.4",
    "eslint": "^9.0",
    "eslint-plugin-vue": "^9.0",
    "eslint-plugin-vuejs-accessibility": "^2.0",
    "eslint-plugin-boundaries": "^4.0",
    "eslint-plugin-perfectionist": "^4.0",
    "prettier": "^3.0",
    "tailwindcss": "^4.0",
    "@tailwindcss/vite": "^4.0",
    "typescript": "^5.7",
    "vite": "^6.0",
    "vitest": "^3.0",
    "vue-tsc": "^2.0",
    "@vitest/coverage-v8": "^3.0",
    "jsdom": "^25.0"
  }
}
